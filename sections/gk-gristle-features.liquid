{% comment %}
  GK Gristle King landing - 3. Solution feature grid
  2x2 icon cards describing what the pedal does. Blocks are fully editable
  in the theme editor; icons use the Tabler webfont loaded by the layout.
{% endcomment %}

<div class="gkl">
  {%- if section.settings.show_top_divider -%}
    <div class="gkl-divider" aria-hidden="true"><hr></div>
  {%- endif -%}

  <section class="gkl-features">
    <div class="gkl-wrap gkl-wrap--wide">
      <div class="gkl-section-head">
        {%- if section.settings.eyebrow != blank -%}
          <p class="gkl-eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="gkl-h2">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.subhead != blank -%}
          <p class="gkl-subhead">{{ section.settings.subhead | escape }}</p>
        {%- endif -%}
      </div>

      <div class="gkl-features__grid">
        {%- for block in section.blocks -%}
          <div class="gkl-feature" {{ block.shopify_attributes }}>
            <i class="ti {{ block.settings.icon | escape }}" aria-hidden="true"></i>
            <h3 class="gkl-feature__title">{{ block.settings.title | escape }}</h3>
            <p class="gkl-feature__text">{{ block.settings.text | escape }}</p>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "GK Gristle - features",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_top_divider",
      "label": "Show top divider",
      "default": true
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "What you're plugging into"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "One box. The whole arsenal."
    },
    {
      "type": "textarea",
      "id": "subhead",
      "label": "Subhead"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Tabler icon class",
          "default": "ti-adjustments"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Clean boost and overdrive"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Dial in warm bluesy breakup or push into searing sustain, all in one box."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "GK Gristle - features",
      "blocks": [
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" }
      ]
    }
  ]
}
{% endschema %}
