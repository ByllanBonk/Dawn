{% comment %}
  GK Gristle King landing (paid traffic)
  - Naked single-CTA conversion page. Rendered on layout/gristle-landing.liquid
    so there is no site nav, header or footer — the only paths off this page
    are the CTA and Shopify checkout.
  - All commerce data (title, price, compare-at price, availability, low stock,
    images, description, variant id) is read LIVE from the Shopify product via
    Liquid. Nothing commerce-related is hardcoded.
  - The CTA is a cart permalink (/cart/VARIANT_ID:1) which lands the buyer
    straight on Shopify checkout, not the cart page.
  - If the product is sold out, the CTA automatically swaps to
    "Join the waiting list" and scrolls to a waitlist email capture that posts
    to Shopify's customer form (a real backend — no browser storage involved).
  - Both states are built and driven by the live inventory flag.
{% endcomment %}

{%- comment -%}
  CONFIG: fallback product handle. The theme editor product picker (section
  setting) wins; this constant is only used when no product is selected.
  One-line fix if the handle ever changes.
{%- endcomment -%}
{%- assign fallback_handle = 'gristle-king-pedal-56' -%}

{%- assign product = section.settings.product -%}
{%- if product == blank -%}
  {%- assign product = all_products[fallback_handle] -%}
{%- endif -%}

{%- assign variant = product.selected_or_first_available_variant | default: product.first_available_variant | default: product.variants.first -%}
{%- assign checkout_url = '/cart/' | append: variant.id | append: ':1' -%}
{%- assign sold_out = false -%}
{%- unless product.available -%}
  {%- assign sold_out = true -%}
{%- endunless -%}

{%- assign low_stock = false -%}
{%- if sold_out == false
  and variant.inventory_management == 'shopify'
  and variant.inventory_policy == 'deny'
  and variant.inventory_quantity > 0
  and variant.inventory_quantity <= section.settings.low_stock_threshold
-%}
  {%- assign low_stock = true -%}
{%- endif -%}

{%- if sold_out -%}
  {%- assign cta_label = 'Join the waiting list' -%}
  {%- assign cta_url = '#waitlist' -%}
{%- else -%}
  {%- assign cta_label = 'Get my Gristle King now' -%}
  {%- assign cta_url = checkout_url -%}
{%- endif -%}

{%- if product == blank or product.empty? -%}
  {%- comment -%}
    Error state: the product could not be found. Pricing must never be
    hardcoded or guessed, so render a clear failure instead of fake data.
  {%- endcomment -%}
  <div class="gkl gkl-error" role="alert">
    <div class="gkl-wrap">
      <p class="gkl-error__title">Product not found</p>
      <p>
        No product selected in the theme editor and no product matches the
        fallback handle “{{ fallback_handle }}”. Pick the Gristle King product
        in the section settings, or update the fallback handle at the top of
        sections/gk-gristle-king-landing.liquid.
      </p>
    </div>
  </div>
  <script>
    console.warn(
      '[gk-gristle-king-landing] Product not found. Checked section setting and fallback handle "{{ fallback_handle }}". No fallback pricing is rendered by design.'
    );
  </script>
{%- else -%}

<div class="gkl" id="section-{{ section.id }}">

  {% comment %} ============ 1. HERO ============ {% endcomment %}
  <header class="gkl-hero">
    <div class="gkl-wrap gkl-hero__inner">
      <span class="gkl-badge">Now built by Fishman for wider availability</span>

      <h1 class="gkl-hero__heading">The Gristle King. The tone Greg Koch built his sound on.</h1>

      <p class="gkl-hero__subhead">
        Designed with Greg Koch and original builder Tim Jauernig. Warm bluesy
        breakup to searing sustain, in one pedal.
      </p>

      <p class="gkl-price">
        <span class="gkl-price__title">{{ product.title | escape }}</span>
        <span class="gkl-price__amount">{{ variant.price | money }}</span>
        {%- if variant.compare_at_price > variant.price -%}
          <s class="gkl-price__compare">{{ variant.compare_at_price | money }}</s>
        {%- endif -%}
      </p>

      <p class="gkl-stock{% if sold_out %} gkl-stock--out{% elsif low_stock %} gkl-stock--low{% endif %}">
        {%- if sold_out -%}
          Sold out — join the waiting list below
        {%- elsif low_stock -%}
          Only {{ variant.inventory_quantity }} left in stock
        {%- else -%}
          In stock and ready to ship
        {%- endif -%}
      </p>

      <a class="gkl-cta" href="{{ cta_url }}">{{ cta_label }}</a>
    </div>
  </header>

  {% comment %} ============ 2. PRODUCT GALLERY ============ {% endcomment %}
  {%- if product.images.size > 0 -%}
    <section class="gkl-gallery" aria-label="{{ product.title | escape }} photos">
      <div class="gkl-wrap">
        <div class="gkl-gallery__grid">
          {%- for image in product.images limit: 3 -%}
            <div class="gkl-gallery__cell">
              {{
                image
                | image_url: width: 1200
                | image_tag:
                  loading: 'lazy',
                  sizes: '(min-width: 750px) 33vw, 100vw',
                  widths: '400, 600, 800, 1000, 1200',
                  class: 'gkl-gallery__img',
                  alt: image.alt | default: product.title
              }}
            </div>
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  {% comment %} ============ 2b. DESCRIPTION FROM SHOPIFY (if present) ============ {% endcomment %}
  {%- if product.description != blank -%}
    <section class="gkl-desc">
      <div class="gkl-wrap gkl-wrap--narrow">
        <p class="gkl-eyebrow">About the pedal</p>
        <div class="gkl-desc__body">{{ product.description }}</div>
      </div>
    </section>
  {%- endif -%}

  {% comment %} ============ 3. DEMO VIDEO ============ {% endcomment %}
  <section class="gkl-video">
    <div class="gkl-wrap gkl-wrap--narrow">
      {%- comment -%}
        The iframe is injected only when the section scrolls near the
        viewport (IntersectionObserver below) to keep initial load light.
      {%- endcomment -%}
      <div
        class="gkl-video__frame"
        data-gkl-video
        data-video-src="{{ section.settings.video_embed_url | escape }}"
        data-video-title="Greg Koch's Secret Weapon? Gristle King Pedal FULL Breakdown"
      ></div>
      <p class="gkl-video__caption">Full pedal breakdown, straight from Greg's channel</p>
    </div>
  </section>

  {% comment %} ============ 4. FEATURE GRID ============ {% endcomment %}
  <section class="gkl-features">
    <div class="gkl-wrap">
      <div class="gkl-features__grid">
        <div class="gkl-feature">
          <i class="ti ti-adjustments gkl-feature__icon" aria-hidden="true"></i>
          <h3 class="gkl-feature__title">Clean boost and overdrive</h3>
          <p class="gkl-feature__text">Dial in warm bluesy breakup or push into searing sustain, all in one box.</p>
        </div>
        <div class="gkl-feature">
          <i class="ti ti-wave-sine gkl-feature__icon" aria-hidden="true"></i>
          <h3 class="gkl-feature__title">Designed with Tim Jauernig</h3>
          <p class="gkl-feature__text">Same signature circuit, same tone DNA the original was built on.</p>
        </div>
        <div class="gkl-feature">
          <i class="ti ti-building-factory-2 gkl-feature__icon" aria-hidden="true"></i>
          <h3 class="gkl-feature__title">Built by Fishman</h3>
          <p class="gkl-feature__text">The same sought-after sound, now produced for wider availability.</p>
        </div>
        <div class="gkl-feature">
          <i class="ti ti-shield-check gkl-feature__icon" aria-hidden="true"></i>
          <h3 class="gkl-feature__title">Road-ready durability</h3>
          <p class="gkl-feature__text">Studio-quality tone built to survive the touring grind.</p>
        </div>
      </div>
    </div>
  </section>

  {% comment %} ============ 5. TESTIMONIALS ============ {% endcomment %}
  {%- comment -%}
    TODO(Dylan): these two quotes are paraphrased from real gear press and
    player forum sentiment and are deliberately unattributed. Swap in a named,
    photographed testimonial (with permission) before this page goes fully live.
  {%- endcomment -%}
  <section class="gkl-testimonials">
    <div class="gkl-wrap">
      <div class="gkl-testimonials__grid">
        <figure class="gkl-testimonial">
          <blockquote>“If you have a Strat or Tele, you better be sitting down when you play it through this pedal.”</blockquote>
          <figcaption>Player forum thread</figcaption>
        </figure>
        <figure class="gkl-testimonial">
          <blockquote>“A dynamic tone sculptor that puts you in control of your sound's destiny.”</blockquote>
          <figcaption>Gear press</figcaption>
        </figure>
      </div>
    </div>
  </section>

  {% comment %} ============ 6. GREG QUOTE ============ {% endcomment %}
  {%- comment -%}
    TODO(Dylan): this quote was DRAFTED for the page — it is not something
    Greg actually said. Get Greg's sign-off (or his own wording) before launch.
  {%- endcomment -%}
  <section class="gkl-quote">
    <div class="gkl-wrap gkl-wrap--narrow">
      <blockquote class="gkl-quote__text">“This is the sound. Been chasing it for twenty years, now anyone can plug it in. We ride!”</blockquote>
      <p class="gkl-quote__attribution">— Greg Koch</p>
    </div>
  </section>

  {% comment %} ============ 7. CLOSING CTA ============ {% endcomment %}
  <section class="gkl-closing">
    <div class="gkl-wrap gkl-wrap--narrow">
      <p class="gkl-price gkl-price--closing">
        <span class="gkl-price__amount">{{ variant.price | money }}</span>
        {%- if variant.compare_at_price > variant.price -%}
          <s class="gkl-price__compare">{{ variant.compare_at_price | money }}</s>
        {%- endif -%}
      </p>
      <a class="gkl-cta" href="{{ cta_url }}">{{ cta_label }}</a>
      <p class="gkl-smallprint">Includes instruction booklet. International orders responsible for customs and duties.</p>
    </div>
  </section>

  {% comment %} ============ WAITLIST (sold-out state only) ============ {% endcomment %}
  {%- if sold_out -%}
    <section class="gkl-waitlist" id="waitlist">
      <div class="gkl-wrap gkl-wrap--narrow">
        <h2 class="gkl-waitlist__heading">Join the waiting list</h2>
        <p class="gkl-waitlist__text">Leave your email and we'll let you know the moment the Gristle King is back in stock.</p>

        {%- form 'customer', class: 'gkl-waitlist__form', id: 'gkl-waitlist-form' -%}
          <input type="hidden" name="contact[tags]" value="gristle-king-waitlist">

          {%- if form.posted_successfully? -%}
            <p class="gkl-waitlist__success" tabindex="-1" autofocus>You're on the list. We'll email you when it's back.</p>
          {%- else -%}
            <div class="gkl-waitlist__row">
              <label class="visually-hidden" for="gkl-waitlist-email">Email address</label>
              <input
                id="gkl-waitlist-email"
                type="email"
                name="contact[email]"
                value="{{ form.email }}"
                placeholder="Email address"
                required
                autocomplete="email"
                autocorrect="off"
                autocapitalize="off"
                {% if form.errors %}
                  autofocus
                  aria-invalid="true"
                  aria-describedby="gkl-waitlist-error"
                {% endif %}
              >
              <button type="submit" class="gkl-cta gkl-cta--form">Join the waiting list</button>
            </div>
            {%- if form.errors -%}
              <p class="gkl-waitlist__error" id="gkl-waitlist-error">
                {{ form.errors.translated_fields.email | capitalize }}
                {{ form.errors.messages.email }}
              </p>
            {%- endif -%}
          {%- endif -%}
        {%- endform -%}
      </div>
    </section>
  {%- endif -%}

  {% comment %} ============ STICKY MOBILE CTA ============ {% endcomment %}
  <div class="gkl-sticky">
    <span class="gkl-sticky__price">
      {{ variant.price | money }}
      {%- if variant.compare_at_price > variant.price -%}
        <s class="gkl-sticky__compare">{{ variant.compare_at_price | money }}</s>
      {%- endif -%}
    </span>
    <a class="gkl-cta gkl-cta--sticky" href="{{ cta_url }}">{{ cta_label }}</a>
  </div>
  <div class="gkl-sticky-spacer" aria-hidden="true"></div>

</div>

<script>
  (function () {
    // Lazy-load the YouTube iframe only once the video section is near view.
    var frames = document.querySelectorAll('[data-gkl-video]');
    if (!frames.length) return;

    function inject(frame) {
      if (frame.dataset.loaded) return;
      frame.dataset.loaded = 'true';
      var iframe = document.createElement('iframe');
      iframe.src = frame.dataset.videoSrc;
      iframe.title = frame.dataset.videoTitle;
      iframe.loading = 'lazy';
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      iframe.setAttribute('allowfullscreen', '');
      iframe.setAttribute('referrerpolicy', 'strict-origin-when-cross-origin');
      frame.appendChild(iframe);
    }

    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              inject(entry.target);
              observer.unobserve(entry.target);
            }
          });
        },
        { rootMargin: '600px 0px' }
      );
      frames.forEach(function (frame) { observer.observe(frame); });
    } else {
      frames.forEach(inject);
    }
  })();
</script>

{%- endif -%}

{% schema %}
{
  "name": "GK Gristle King landing",
  "tag": "section",
  "class": "section-gristle-king-landing",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "info": "Leave empty to use the fallback handle defined at the top of the section file."
    },
    {
      "type": "range",
      "id": "low_stock_threshold",
      "label": "Low stock threshold",
      "info": "Show “Only X left in stock” at or below this quantity.",
      "min": 1,
      "max": 20,
      "step": 1,
      "default": 5
    },
    {
      "type": "text",
      "id": "video_embed_url",
      "label": "Demo video embed URL",
      "default": "https://www.youtube.com/embed/LG6n_28SW_c"
    }
  ],
  "presets": [
    {
      "name": "GK Gristle King landing"
    }
  ]
}
{% endschema %}
