{% comment %}
  GK Gristle King landing - 7. Final CTA
  Repeats the primary CTA with live price from Shopify, plus the customs
  small print. When the product is sold out the CTA swaps to a waitlist
  email capture posting to Shopify's customer form (a real backend - no
  browser storage), tagged gristle-king-waitlist. Also renders the sticky
  mobile CTA bar pinned to the bottom of the viewport (mobile only).
{% endcomment %}

{%- comment -%}
  The Gristle King fallback only applies on the Gristle King template so a
  misconfigured product never silently shows another product's price.
{%- endcomment -%}
{%- assign product = section.settings.product -%}
{%- if product == blank and template.suffix == 'gristle-king' -%}
  {%- assign product = all_products['gristle-king-pedal-56'] -%}
{%- endif -%}
{%- assign variant = product.selected_or_first_available_variant | default: product.variants.first -%}
{%- assign checkout_url = '/cart/' | append: variant.id | append: ':1' -%}

{%- assign sold_out = false -%}
{%- unless product.available -%}{%- assign sold_out = true -%}{%- endunless -%}

{%- if sold_out -%}
  {%- assign cta_label = section.settings.cta_label_soldout -%}
  {%- assign cta_url = '#waitlist' -%}
{%- else -%}
  {%- assign cta_label = section.settings.cta_label -%}
  {%- assign cta_url = checkout_url -%}
{%- endif -%}

{%- if product == blank or product.empty? -%}
  <script>
    console.warn('[gk-gristle-cta] No resolvable product for this section. Pick the product in the theme editor. CTA not rendered - no fallback pricing by design.');
  </script>
{%- else -%}

<div class="gkl">
  {%- if section.settings.show_top_divider -%}
    <div class="gkl-divider" aria-hidden="true"><hr></div>
  {%- endif -%}

  <section class="gkl-cta">
    <div class="gkl-wrap">
      {%- if section.settings.eyebrow != blank -%}
        <p class="gkl-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="gkl-h2">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      <p class="gkl-price">
        <span class="gkl-price__label">{{ product.title | escape }}</span>
        <span class="gkl-price__amount">{{ variant.price | money }}</span>
        {%- if variant.compare_at_price > variant.price -%}
          <s class="gkl-price__compare">{{ variant.compare_at_price | money }}</s>
        {%- endif -%}
      </p>

      {%- if sold_out -%}
        <p class="gkl-stock gkl-stock--out">Sold out. Join the waiting list below</p>
      {%- endif -%}

      <div class="gkl-cta__button-row">
        <a class="gkl-btn" href="{{ cta_url }}">{{ cta_label | escape }}</a>
      </div>

      {%- if section.settings.smallprint != blank -%}
        <p class="gkl-smallprint">{{ section.settings.smallprint | escape }}</p>
      {%- endif -%}

      {%- if sold_out -%}
        <div class="gkl-waitlist" id="waitlist">
          <h3 class="gkl-waitlist__heading">{{ section.settings.waitlist_heading | escape }}</h3>
          <p class="gkl-waitlist__text">{{ section.settings.waitlist_text | escape }}</p>

          {%- form 'customer', class: 'gkl-waitlist__form', id: 'gkl-waitlist-form' -%}
            <input type="hidden" name="contact[tags]" value="{{ section.settings.waitlist_tag | default: 'gristle-king-waitlist' | escape }}">

            {%- if form.posted_successfully? -%}
              <p class="gkl-waitlist__success" tabindex="-1" autofocus>You're on the list. We'll email you when it's back.</p>
            {%- else -%}
              <div class="gkl-waitlist__row">
                <label class="visually-hidden" for="gkl-waitlist-email">Email address</label>
                <input
                  id="gkl-waitlist-email"
                  type="email"
                  name="contact[email]"
                  value="{{ form.email }}"
                  placeholder="Email address"
                  required
                  autocomplete="email"
                  autocorrect="off"
                  autocapitalize="off"
                  {% if form.errors %}
                    autofocus
                    aria-invalid="true"
                    aria-describedby="gkl-waitlist-error"
                  {% endif %}
                >
                <button type="submit" class="gkl-btn">{{ section.settings.cta_label_soldout | escape }}</button>
              </div>
              {%- if form.errors -%}
                <p class="gkl-waitlist__error" id="gkl-waitlist-error">
                  {{ form.errors.translated_fields.email | capitalize }}
                  {{ form.errors.messages.email }}
                </p>
              {%- endif -%}
            {%- endif -%}
          {%- endform -%}
        </div>
      {%- endif -%}
    </div>
  </section>

  {% comment %} Sticky mobile CTA bar (hidden ≥ 750px via CSS) {% endcomment %}
  <div class="gkl-sticky">
    <span class="gkl-sticky__price">
      {{ variant.price | money }}
      {%- if variant.compare_at_price > variant.price -%}
        <s class="gkl-sticky__compare">{{ variant.compare_at_price | money }}</s>
      {%- endif -%}
    </span>
    <a class="gkl-btn gkl-btn--sticky" href="{{ cta_url }}">{{ cta_label | escape }}</a>
  </div>
  <div class="gkl-sticky-spacer" aria-hidden="true"></div>
</div>

{%- endif -%}

{% schema %}
{
  "name": "GK Gristle - final CTA",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_top_divider",
      "label": "Show top divider",
      "default": true
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "info": "Required on every page except the Gristle King page, which falls back to the Gristle King product."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Ready when you are"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Gristle King is waiting"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label (in stock)",
      "default": "Get my Gristle King now"
    },
    {
      "type": "text",
      "id": "cta_label_soldout",
      "label": "CTA label (sold out)",
      "default": "Join the waiting list"
    },
    {
      "type": "text",
      "id": "smallprint",
      "label": "Small print",
      "default": "Includes instruction booklet. International orders responsible for customs and duties."
    },
    {
      "type": "text",
      "id": "waitlist_tag",
      "label": "Waitlist customer tag",
      "info": "Tag applied to captured emails in Shopify customers, one per product.",
      "default": "gristle-king-waitlist"
    },
    {
      "type": "text",
      "id": "waitlist_heading",
      "label": "Waitlist heading",
      "default": "Join the waiting list"
    },
    {
      "type": "text",
      "id": "waitlist_text",
      "label": "Waitlist text",
      "default": "Leave your email and we'll let you know the moment the Gristle King is back in stock."
    }
  ],
  "presets": [
    { "name": "GK Gristle - final CTA" }
  ]
}
{% endschema %}
