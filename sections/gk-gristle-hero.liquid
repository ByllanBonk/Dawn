{% comment %}
  GK Gristle King landing - 1. Hero
  Above the fold: wordmark (trust, not a link - no paths off this page),
  kicker badge, benefit-led headline, subhead, trust bullets, live price +
  availability from Shopify, and the primary CTA straight to checkout.
  Commerce data is never hardcoded: price, compare-at, stock and image all
  come from the product picked in the section settings. The Gristle King
  fallback only applies on the Gristle King template; on any other page an
  unset or unresolvable product shows the error state below instead of
  silently rendering another product's info.
{% endcomment %}

{%- assign product = section.settings.product -%}
{%- if product == blank and template.suffix == 'gristle-king' -%}
  {%- assign product = all_products['gristle-king-pedal-56'] -%}
{%- endif -%}
{%- assign variant = product.selected_or_first_available_variant | default: product.variants.first -%}
{%- assign checkout_url = '/cart/' | append: variant.id | append: ':1' -%}

{%- assign sold_out = false -%}
{%- unless product.available -%}{%- assign sold_out = true -%}{%- endunless -%}

{%- assign low_stock = false -%}
{%- if sold_out == false
  and variant.inventory_management == 'shopify'
  and variant.inventory_policy == 'deny'
  and variant.inventory_quantity > 0
  and variant.inventory_quantity <= section.settings.low_stock_threshold
-%}
  {%- assign low_stock = true -%}
{%- endif -%}

{%- if sold_out -%}
  {%- assign cta_label = section.settings.cta_label_soldout -%}
  {%- assign cta_url = '#waitlist' -%}
{%- else -%}
  {%- assign cta_label = section.settings.cta_label -%}
  {%- assign cta_url = checkout_url -%}
{%- endif -%}

{%- if product == blank or product.empty? -%}
  <div class="gkl gkl-error" role="alert">
    <div class="gkl-wrap--wide gkl-wrap">
      <p class="gkl-error__title">Product not found</p>
      <p>
        This section has no resolvable product. Open the theme editor and
        pick this page's product in the hero, proof and final CTA sections.
        Pricing is never hardcoded by design.
      </p>
    </div>
  </div>
  <script>
    console.warn('[gk-gristle-hero] No resolvable product for this section. Pick the product in the theme editor. No fallback pricing is rendered by design.');
  </script>
{%- else -%}

<div class="gkl">
  <header class="gkl-hero">
    <div class="gkl-hero__glow" aria-hidden="true"></div>
    <div class="gkl-wrap gkl-wrap--wide">

      <p class="gkl-wordmark">Greg <span>Koch</span></p>

      <div class="gkl-hero__grid">
        <div class="gkl-hero__copy">
          {%- if section.settings.kicker != blank -%}
            <span class="gkl-kicker">{{ section.settings.kicker | escape }}</span>
          {%- endif -%}

          <h1 class="gkl-hero__heading">
            {{ section.settings.heading_line1 | escape }}
            <em>{{ section.settings.heading_line2 | escape }}</em>
          </h1>

          {%- if section.settings.subhead != blank -%}
            <p class="gkl-hero__subhead">{{ section.settings.subhead | escape }}</p>
          {%- endif -%}

          <ul class="gkl-hero__bullets">
            {%- for block in section.blocks -%}
              <li {{ block.shopify_attributes }}>
                <i class="ti {{ block.settings.icon | escape }}" aria-hidden="true"></i>
                <span>{{ block.settings.text | escape }}</span>
              </li>
            {%- endfor -%}
          </ul>

          <div class="gkl-hero__buy">
            <p class="gkl-price">
              <span class="gkl-price__label">{{ product.title | escape }}</span>
              <span class="gkl-price__amount">{{ variant.price | money }}</span>
              {%- if variant.compare_at_price > variant.price -%}
                <s class="gkl-price__compare">{{ variant.compare_at_price | money }}</s>
              {%- endif -%}
            </p>

            <p class="gkl-stock{% if sold_out %} gkl-stock--out{% elsif low_stock %} gkl-stock--low{% endif %}">
              {%- if sold_out -%}
                Sold out. Join the waiting list below
              {%- elsif low_stock -%}
                Only {{ variant.inventory_quantity }} left in stock
              {%- else -%}
                In stock and ready to ship
              {%- endif -%}
            </p>

            {%- if sold_out -%}
              {%- if section.settings.soldout_note != blank -%}
                <p class="gkl-notify__note">{{ section.settings.soldout_note | escape }}</p>
              {%- endif -%}
              {%- comment -%}
                Inline email capture, revealed by the CTA itself. Not a popup
                and not a jump to the bottom of the page. Posts to Shopify's
                customer form (a real backend), tagged per product.
              {%- endcomment -%}
              <details class="gkl-notify">
                <summary class="gkl-btn">{{ cta_label | escape }}</summary>
                <div class="gkl-notify__panel">
                  {%- form 'customer', class: 'gkl-notify__form', id: 'gkl-hero-notify' -%}
                    <input type="hidden" name="contact[tags]" value="{{ section.settings.waitlist_tag | default: 'gristle-king-waitlist' | escape }}">
                    {%- if form.posted_successfully? -%}
                      <p class="gkl-notify__success">You're on the list. We'll email you the second it's ready.</p>
                    {%- else -%}
                      <div class="gkl-notify__row">
                        <label class="visually-hidden" for="gkl-hero-notify-email">Email address</label>
                        <input
                          id="gkl-hero-notify-email"
                          type="email"
                          name="contact[email]"
                          value="{{ form.email }}"
                          placeholder="Email address"
                          required
                          autocomplete="email"
                          autocorrect="off"
                          autocapitalize="off"
                        >
                        <button type="submit" class="gkl-btn gkl-btn--compact">Notify me</button>
                      </div>
                      {%- if form.errors -%}
                        <p class="gkl-notify__error">
                          {{ form.errors.translated_fields.email | capitalize }}
                          {{ form.errors.messages.email }}
                        </p>
                      {%- endif -%}
                    {%- endif -%}
                  {%- endform -%}
                </div>
              </details>
              <script>
                if (window.location.search.indexOf('customer_posted=true') !== -1) {
                  document.querySelectorAll('.gkl-notify').forEach(function (d) { d.open = true; });
                }
              </script>
            {%- else -%}
              <a class="gkl-btn" href="{{ cta_url }}">{{ cta_label | escape }}</a>
            {%- endif -%}

            {%- if section.settings.microcopy != blank -%}
              <p class="gkl-microcopy">{{ section.settings.microcopy | escape }}</p>
            {%- endif -%}

            {%- if section.settings.bonus_enabled -%}
              {%- comment -%}
                Collector's kit bonus: automatically included free with the
                order, so there is no accept/decline step. Just the card.
              {%- endcomment -%}
              <div class="gkl-bonus">
                <div class="gkl-bonus__thumbs">
                  {%- if section.settings.bonus_image_1 != blank -%}
                    {{ section.settings.bonus_image_1 | image_url: width: 160 | image_tag: loading: 'lazy', class: 'gkl-bonus__thumb', alt: '' }}
                  {%- else -%}
                    <span class="gkl-bonus__thumb gkl-bonus__thumb--icon"><i class="ti ti-guitar-pick" aria-hidden="true"></i></span>
                  {%- endif -%}
                  {%- if section.settings.bonus_image_2 != blank -%}
                    {{ section.settings.bonus_image_2 | image_url: width: 160 | image_tag: loading: 'lazy', class: 'gkl-bonus__thumb', alt: '' }}
                  {%- else -%}
                    <span class="gkl-bonus__thumb gkl-bonus__thumb--icon"><i class="ti ti-tools" aria-hidden="true"></i></span>
                  {%- endif -%}
                </div>
                <div class="gkl-bonus__body">
                  <span class="gkl-bonus__badge">{{ section.settings.bonus_badge | escape }}</span>
                  {%- if section.settings.bonus_text != blank -%}
                    <p class="gkl-bonus__text">{{ section.settings.bonus_text | escape }}</p>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          </div>
        </div>

        <div class="gkl-hero__media">
          <div class="gkl-hero__frame">
            {%- assign hero_image = section.settings.image | default: product.featured_image -%}
            {%- if hero_image != blank -%}
              {{
                hero_image
                | image_url: width: 1400
                | image_tag:
                  loading: 'eager',
                  fetchpriority: 'high',
                  sizes: '(min-width: 750px) 46vw, 100vw',
                  widths: '500, 700, 900, 1100, 1400',
                  class: 'gkl-hero__img',
                  alt: hero_image.alt | default: product.title
              }}
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  </header>
</div>

{%- endif -%}

{% schema %}
{
  "name": "GK Gristle - hero",
  "tag": "section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "info": "Required on every page except the Gristle King page, which falls back to the Gristle King product."
    },
    {
      "type": "range",
      "id": "low_stock_threshold",
      "label": "Low stock threshold",
      "min": 1,
      "max": 20,
      "step": 1,
      "default": 5
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker badge",
      "default": "Now built by Fishman for wider availability"
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Heading line 1",
      "default": "Your tone."
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Heading line 2 (accent color)",
      "default": "No matter what amp they throw at you."
    },
    {
      "type": "textarea",
      "id": "subhead",
      "label": "Subhead",
      "default": "The Gristle King. The pedal Greg Koch built his sound on. Designed with Greg and original builder Tim Jauernig. Warm bluesy breakup to searing sustain, in one pedal."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label (in stock)",
      "default": "Get my Gristle King now"
    },
    {
      "type": "text",
      "id": "cta_label_soldout",
      "label": "CTA label (sold out)",
      "default": "Join the waiting list"
    },
    {
      "type": "text",
      "id": "microcopy",
      "label": "Microcopy under CTA",
      "default": "Ships fast. Includes instruction booklet."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image",
      "info": "Leave empty to use the product's featured image from Shopify."
    },
    {
      "type": "text",
      "id": "soldout_note",
      "label": "Sold-out note (Greg voice)",
      "info": "Shown near the CTA when the product is sold out. Explains why without sounding like an error message."
    },
    {
      "type": "text",
      "id": "waitlist_tag",
      "label": "Waitlist customer tag",
      "info": "Tag applied to emails captured by the inline sold-out form.",
      "default": "gristle-king-waitlist"
    },
    {
      "type": "header",
      "content": "Collector's kit bonus"
    },
    {
      "type": "checkbox",
      "id": "bonus_enabled",
      "label": "Show bonus card",
      "default": false,
      "info": "Free kit included with every order: no accept or decline step."
    },
    {
      "type": "text",
      "id": "bonus_badge",
      "label": "Bonus badge",
      "default": "Included free"
    },
    {
      "type": "text",
      "id": "bonus_text",
      "label": "Bonus text"
    },
    {
      "type": "image_picker",
      "id": "bonus_image_1",
      "label": "Bonus thumbnail 1 (picks)"
    },
    {
      "type": "image_picker",
      "id": "bonus_image_2",
      "label": "Bonus thumbnail 2 (capo)"
    }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Trust bullet",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Tabler icon class",
          "default": "ti-circle-check"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "A super dynamic, amp-like overdrive that sounds great at any volume"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "GK Gristle - hero",
      "blocks": [
        { "type": "bullet" },
        { "type": "bullet" },
        { "type": "bullet" }
      ]
    }
  ]
}
{% endschema %}
