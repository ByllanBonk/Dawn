{%- style -%}
  /* ── GK Press Hero (scoped under .gk-press-hero) ────────── */
  .gk-press-hero {
    background-color: #0D0D0D;
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    position: relative;
    overflow: hidden;
  }

  /* Cinematic radial glow behind the headline */
  .gk-press-hero::before {
    content: '';
    position: absolute;
    top: -6%;
    left: 50%;
    transform: translateX(-50%);
    width: 900px;
    height: 480px;
    background: radial-gradient(ellipse at center, rgba(232, 105, 10, 0.11) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
  }

  /* Bottom hairline fade */
  .gk-press-hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(232, 105, 10, 0.3), transparent);
    z-index: 1;
  }

  .gk-press-hero__inner {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 24px;
    position: relative;
    z-index: 2;
  }

  .gk-press-hero__content {
    text-align: center;
    max-width: 860px;
    margin: 0 auto;
  }

  /* Kicker - "IN THE PRESS" */
  .gk-press-hero__eyebrow {
    display: block;
    font-family: 'DM Mono', monospace;
    color: #E8690A;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 4px;
    text-transform: uppercase;
    margin-bottom: 22px;
  }

  /* Headline - "PRESS & MEDIA" with orange ampersand */
  .gk-press-hero__heading {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3rem, 8vw, 4.75rem);
    font-weight: 400;
    color: #F2F2F2;
    text-transform: uppercase;
    letter-spacing: 3px;
    margin: 0 0 8px;
    line-height: 0.95;
  }

  .gk-press-hero__heading .gk-ph-amp {
    color: #E8690A;
  }

  /* Divider: hairlines + 45deg diamond */
  .gk-press-hero__divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    margin: 28px auto;
    width: auto;
  }

  .gk-press-hero__divider-line {
    flex: 0 0 80px;
    width: 80px;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(232, 105, 10, 0.55));
  }

  .gk-press-hero__divider-line:last-child {
    background: linear-gradient(to right, rgba(232, 105, 10, 0.55), transparent);
  }

  .gk-press-hero__divider-dot {
    width: 7px;
    height: 7px;
    background-color: #E8690A;
    transform: rotate(45deg);
    flex-shrink: 0;
    box-shadow: 0 0 12px rgba(232, 105, 10, 0.85), 0 0 24px rgba(232, 105, 10, 0.35);
  }

  /* Lede paragraph */
  .gk-press-hero__subheading {
    font-family: 'DM Sans', system-ui, -apple-system, sans-serif;
    font-size: clamp(1.125rem, 1.6vw, 1.25rem);
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0.2px;
    color: #A6A6A6;
    line-height: 1.8;
    margin: 0 auto 36px;
    max-width: 640px;
  }

  /* Optional second paragraph */
  .gk-press-hero__intro {
    font-family: 'DM Sans', system-ui, -apple-system, sans-serif;
    font-size: 1rem;
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0.2px;
    color: #8A8A8A;
    line-height: 1.75;
    max-width: 580px;
    margin: -18px auto 36px;
  }

  /* ── Press Kit CTA - uses .button (molten orange from base.css) ── */
  .gk-press-hero__cta {
    margin: 0 auto 8px;
  }

  /* Press Kit button - matches the site-wide pill button (see gk-hero__btn) */
  .gk-press-hero__kit-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    text-decoration: none;
    border: 1px solid #E8690A !important;
    border-radius: 999px;
    padding: 14px 36px !important;
    min-width: 0;
    min-height: 0;
    font-family: 'DM Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
    font-weight: 500;
    font-size: 13px !important;
    letter-spacing: 0.12em !important;
    text-transform: uppercase;
    color: #0D0D0D !important;
    background: #E8690A !important;
    box-shadow: none !important;
    transition: transform 140ms ease, opacity 140ms ease, box-shadow 140ms ease;
  }

  .gk-press-hero__kit-btn:hover {
    opacity: 0.92;
    transform: translateY(-1px);
    box-shadow: 0 10px 26px rgba(232, 105, 10, 0.28) !important;
  }

  .gk-press-hero__kit-btn:focus-visible {
    outline: 2px solid rgba(232, 105, 10, 0.75);
    outline-offset: 3px;
  }

  .gk-press-hero__kit-btn svg {
    width: 15px;
    height: 15px;
    fill: #0D0D0D;
    flex-shrink: 0;
  }

  /* ── Press/promo contact line (sits directly under the press kit button) ── */
  .gk-press-hero__contact-line {
    font-family: 'DM Sans', system-ui, -apple-system, sans-serif;
    font-size: 15px;
    line-height: 1.5;
    color: #A6A6A6;
    margin: 16px auto 0;
  }

  .gk-press-hero__contact-link {
    color: #E8690A;
    text-decoration: none;
    border-bottom: 1px solid rgba(232, 105, 10, 0.35);
    padding-bottom: 1px;
    transition: color 150ms ease, border-color 150ms ease;
  }

  .gk-press-hero__contact-link:hover {
    color: #FF7E1F;
    border-bottom-color: #E8690A;
  }

  .gk-press-hero__contact-link:focus-visible {
    outline: 2px solid rgba(232, 105, 10, 0.75);
    outline-offset: 3px;
  }

  /* ── Featured In ── */
  .gk-press-hero__featured-in {
    margin-top: 72px;
    padding-top: 48px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .gk-press-hero__featured-in-label {
    font-family: 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 4px;
    font-size: 0.85rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.45);
    display: block;
    margin-bottom: 28px;
  }

  /* Cards grid: 3-up desktop, 2-up tablet, 2-up (then 1-up) mobile */
  .gk-press-hero__pub-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    max-width: 840px;
    margin: 0 auto;
  }

  /* Each publication card */
  .gk-press-hero__pub-card {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(180deg, #171717 0%, #101010 100%);
    border: 1px solid #262626;
    border-radius: 6px;
    padding: 28px 18px;
    text-align: center;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
    font-family: 'Bebas Neue', sans-serif;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    font-size: 1.4rem;
    font-weight: 400;
    line-height: 1.15;
    color: #CFCFCF;
    transition: border-color 200ms ease, color 200ms ease, box-shadow 200ms ease, transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
    overflow: hidden;
  }

  /* Top-edge highlight hairline */
  .gk-press-hero__pub-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 14%;
    right: 14%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.22), transparent);
    pointer-events: none;
  }

  .gk-press-hero__pub-card:hover {
    border-color: rgba(232, 105, 10, 0.6);
    color: #F0A060;
    transform: translateY(-3px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 12px 28px rgba(0, 0, 0, 0.45),
      0 0 24px rgba(232, 105, 10, 0.12);
  }

  /* ── Responsive ── */
  @media screen and (max-width: 989px) {
    .gk-press-hero::before {
      width: 640px;
      height: 400px;
    }
    .gk-press-hero__pub-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .gk-press-hero {
      padding: {{ section.settings.padding_top | times: 0.75 | round }}px 0 {{ section.settings.padding_bottom | times: 0.75 | round }}px;
    }
    .gk-press-hero__heading {
      font-size: clamp(2.75rem, 12vw, 3.5rem);
      letter-spacing: 2px;
    }
    .gk-press-hero__subheading {
      font-size: 1.0625rem;
    }
    .gk-press-hero__divider-line {
      flex: 0 0 60px;
      width: 60px;
    }
    .gk-press-hero__featured-in {
      margin-top: 56px;
      padding-top: 40px;
    }
    .gk-press-hero__pub-card {
      padding: 22px 14px;
      font-size: 1.2rem;
      letter-spacing: 2px;
    }
  }

  @media screen and (max-width: 480px) {
    .gk-press-hero__pub-grid {
      grid-template-columns: 1fr;
      max-width: 320px;
    }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .gk-press-hero__pub-card:hover,
    .gk-press-hero__kit-btn:hover {
      transform: none;
    }
  }
{%- endstyle -%}

<section class="gk-press-hero" id="section-{{ section.id }}">
  <div class="gk-press-hero__inner">
    <div class="gk-press-hero__content">

      {%- if section.settings.eyebrow != blank -%}
        <span class="gk-press-hero__eyebrow">{{ section.settings.eyebrow | escape }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        {%- comment -%} Color the literal "&" in the heading orange - escape first, then wrap the entity. {%- endcomment -%}
        {%- assign heading_safe = section.settings.heading | escape -%}
        {%- assign heading_html = heading_safe | replace: '&amp;', '<span class="gk-ph-amp">&amp;</span>' -%}
        <h1 class="gk-press-hero__heading">{{ heading_html }}</h1>
      {%- endif -%}

      <div class="gk-press-hero__divider" aria-hidden="true">
        <span class="gk-press-hero__divider-line"></span>
        <span class="gk-press-hero__divider-dot"></span>
        <span class="gk-press-hero__divider-line"></span>
      </div>

      {%- if section.settings.subheading != blank -%}
        <p class="gk-press-hero__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}

      {%- if section.settings.intro_text != blank -%}
        <p class="gk-press-hero__intro">{{ section.settings.intro_text | escape }}</p>
      {%- endif -%}

      {%- if section.settings.press_kit_url != blank -%}
        <div class="gk-press-hero__cta">
          <a
            href="{{ section.settings.press_kit_url }}"
            class="gk-press-hero__kit-btn button"
            {% unless section.settings.press_kit_url contains 'files.' or section.settings.press_kit_url contains '.pdf' %}
              target="_blank" rel="noopener noreferrer"
            {% endunless %}
            download>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M10 13.5l-4-4h2.5V3h3v6.5H14l-4 4zm-6 3.5h12v-1.5H4V17z"/>
            </svg>
            {{ section.settings.press_kit_label | default: 'Download Press Kit' | escape }}
          </a>
        </div>
      {%- endif -%}

      <p class="gk-press-hero__contact-line">
        For press or promotional inquiries, <a class="gk-press-hero__contact-link" href="{{ pages['contact'].url | default: '/pages/contact' }}">contact us</a>
      </p>

      {%- if section.settings.show_featured_in -%}
        {%- assign has_pubs = false -%}
        {%- if section.settings.pub_1 != blank or section.settings.pub_2 != blank or section.settings.pub_3 != blank or section.settings.pub_4 != blank or section.settings.pub_5 != blank or section.settings.pub_6 != blank -%}
          {%- assign has_pubs = true -%}
        {%- endif -%}

        {%- if has_pubs -%}
          <div class="gk-press-hero__featured-in">
            <span class="gk-press-hero__featured-in-label">Featured In</span>
            <div class="gk-press-hero__pub-grid">
              {%- if section.settings.pub_1 != blank -%}
                <div class="gk-press-hero__pub-card">{{ section.settings.pub_1 | escape }}</div>
              {%- endif -%}
              {%- if section.settings.pub_2 != blank -%}
                <div class="gk-press-hero__pub-card">{{ section.settings.pub_2 | escape }}</div>
              {%- endif -%}
              {%- if section.settings.pub_3 != blank -%}
                <div class="gk-press-hero__pub-card">{{ section.settings.pub_3 | escape }}</div>
              {%- endif -%}
              {%- if section.settings.pub_4 != blank -%}
                <div class="gk-press-hero__pub-card">{{ section.settings.pub_4 | escape }}</div>
              {%- endif -%}
              {%- if section.settings.pub_5 != blank -%}
                <div class="gk-press-hero__pub-card">{{ section.settings.pub_5 | escape }}</div>
              {%- endif -%}
              {%- if section.settings.pub_6 != blank -%}
                <div class="gk-press-hero__pub-card">{{ section.settings.pub_6 | escape }}</div>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endif -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "GK Press Hero",
  "tag": "section",
  "class": "gk-press-hero-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow / Kicker",
      "default": "In the Press"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Headline",
      "default": "Press & Media",
      "info": "The '&' character will automatically render in orange."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Lede Paragraph",
      "default": "Greg Koch has been featured in leading guitar publications, interviews, and music media outlets around the world."
    },
    {
      "type": "textarea",
      "id": "intro_text",
      "label": "Intro Paragraph (optional)",
      "info": "Optional second line of supporting copy beneath the lede."
    },
    {
      "type": "header",
      "content": "Press Kit Download"
    },
    {
      "type": "url",
      "id": "press_kit_url",
      "label": "Press Kit File URL",
      "info": "Upload your press kit PDF to Files in Shopify admin, then paste the URL here. Leave blank to hide the button."
    },
    {
      "type": "text",
      "id": "press_kit_label",
      "label": "Button Label",
      "default": "Download Press Kit"
    },
    {
      "type": "header",
      "content": "Featured In"
    },
    {
      "type": "checkbox",
      "id": "show_featured_in",
      "label": "Show Featured In",
      "default": true
    },
    {
      "type": "text",
      "id": "pub_1",
      "label": "Publication 1",
      "default": "Relix"
    },
    {
      "type": "text",
      "id": "pub_2",
      "label": "Publication 2",
      "default": "Vintage Guitar"
    },
    {
      "type": "text",
      "id": "pub_3",
      "label": "Publication 3",
      "default": "Guitar Player"
    },
    {
      "type": "text",
      "id": "pub_4",
      "label": "Publication 4",
      "default": "Premier Guitar"
    },
    {
      "type": "text",
      "id": "pub_5",
      "label": "Publication 5",
      "default": "Guitar World"
    },
    {
      "type": "text",
      "id": "pub_6",
      "label": "Publication 6",
      "default": "Palm Beach Arts"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 40,
      "max": 160,
      "step": 8,
      "default": 96,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 40,
      "max": 160,
      "step": 8,
      "default": 96,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "GK Press Hero"
    }
  ]
}
{% endschema %}
