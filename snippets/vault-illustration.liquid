      <line x1="82" y1="20" x2="82" y2="74"/>
      <line x1="94" y1="20" x2="94" y2="74"/>
      <line x1="106" y1="20" x2="106" y2="74"/>
      <line x1="118" y1="20" x2="118" y2="74"/>
