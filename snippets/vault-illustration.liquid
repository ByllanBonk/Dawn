{%- comment -%}
  Custom SVG illustration for each Gristle Vault lesson card image well.
  Usage: {% render 'vault-illustration', key: 'pick' %}
  Keys: pick travis chords outside tone blues song clinic
  All art: viewBox 0 0 200 90, strokes/fills #C8601A at varying opacities,
  1.5px strokes (2px nut line on the chord diagram), no decorative filler.
{%- endcomment -%}
{%- assign k = key | default: 'pick' -%}
{%- case k -%}
{%- when 'pick' -%}
  {%- comment -%} Pick-attack starburst over three strings {%- endcomment -%}
  <svg viewBox="0 0 200 90" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <defs>
      <radialGradient id="vst-pick-burst" gradientUnits="userSpaceOnUse" cx="100" cy="34" r="26">
        <stop offset="0.45" stop-color="#C8601A" stop-opacity="1"/>
        <stop offset="1" stop-color="#C8601A" stop-opacity="0.2"/>
      </radialGradient>
    </defs>
    <g stroke="url(#vst-pick-burst)" stroke-width="1.5" stroke-linecap="round">
      <line x1="112" y1="34" x2="124" y2="34"/>
      <line x1="108.5" y1="42.5" x2="117" y2="51"/>
      <line x1="100" y1="46" x2="100" y2="58"/>
      <line x1="91.5" y1="42.5" x2="83" y2="51"/>
      <line x1="88" y1="34" x2="76" y2="34"/>
      <line x1="91.5" y1="25.5" x2="83" y2="17"/>
      <line x1="100" y1="22" x2="100" y2="10"/>
      <line x1="108.5" y1="25.5" x2="117" y2="17"/>
    </g>
    <path d="M100 26 L107.5 34 L100 44 L92.5 34 Z" stroke="#C8601A" stroke-width="1.5" fill="#C8601A" fill-opacity="0.08" stroke-linejoin="round"/>
    <g stroke="#C8601A" stroke-width="1.5" stroke-linecap="round">
      <line x1="40" y1="64" x2="160" y2="64" opacity="0.45"/>
      <path d="M40 72 C68 72 84 72 91 68.5 Q100 64 109 68.5 C116 72 132 72 160 72" opacity="0.7"/>
      <line x1="40" y1="80" x2="160" y2="80" opacity="0.45"/>
    </g>
  </svg>
{%- when 'travis' -%}
  {%- comment -%} Boom-chuck grid: alternating thumb bass and finger chord hits {%- endcomment -%}
  <svg viewBox="0 0 200 90" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <g stroke="#C8601A" stroke-width="1.5">
      <circle cx="80" cy="12" r="5" fill="#C8601A" fill-opacity="1"/>
      <circle cx="80" cy="28" r="5" opacity="0.3"/>
      <circle cx="80" cy="44" r="5" fill="#C8601A" fill-opacity="1"/>
      <circle cx="80" cy="60" r="5" opacity="0.3"/>
      <circle cx="120" cy="12" r="5" opacity="0.3"/>
      <circle cx="120" cy="28" r="5" fill="#C8601A" fill-opacity="0.5"/>
      <circle cx="120" cy="44" r="5" opacity="0.3"/>
      <circle cx="120" cy="60" r="5" fill="#C8601A" fill-opacity="0.5"/>
    </g>
    <g fill="#C8601A" opacity="0.4" font-family="'Bebas Neue', sans-serif" font-size="8" letter-spacing="1" text-anchor="middle">
      <text x="80" y="80">BASS</text>
      <text x="120" y="80">CHORD</text>
    </g>
  </svg>
{%- when 'chords' -%}
