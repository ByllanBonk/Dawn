{%- liquid
  comment
    GK Hero. One section, two modes (standard and release).
    Switching modes is a single dropdown in the customizer.
    Both modes render the identical DOM structure so there is
    no layout shift when the mode changes.
  endcomment

  assign mode = section.settings.mode

  if mode == 'release'
    assign eyebrow = section.settings.rel_eyebrow
    assign heading = section.settings.rel_heading
    assign subheading = section.settings.rel_subheading
    assign button_label = section.settings.rel_button_label
    assign button_link = section.settings.rel_button_link
    if section.settings.rel_image != blank
      assign hero_image = section.settings.rel_image
    else
      assign hero_image = section.settings.image
    endif
  else
    assign eyebrow = section.settings.std_eyebrow
    assign heading = section.settings.std_heading
    assign subheading = section.settings.std_subheading
    assign button_label = section.settings.std_button_label
    assign button_link = section.settings.std_button_link
    assign hero_image = section.settings.image
  endif
-%}

{%- style -%}
  #GkHero-{{ section.id }} {
    position: relative;
    width: 100%;
    min-height: {{ section.settings.hero_height }}vh;
    display: flex;
    align-items: {{ section.settings.content_position }};
    justify-content: center;
    overflow: hidden;
    background-color: #0D0D0D;
  }

  #GkHero-{{ section.id }} .gk-hero__media {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    overflow: hidden;
  }

  #GkHero-{{ section.id }} .gk-hero__media img,
  #GkHero-{{ section.id }} .gk-hero__media video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ section.settings.image_position }};
  }

  #GkHero-{{ section.id }} .gk-hero__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to {{ section.settings.gradient_direction }},
      rgba(13, 13, 13, {{ section.settings.overlay_opacity | divided_by: 100.0 }}) 0%,
      rgba(13, 13, 13, {{ section.settings.overlay_end_opacity | divided_by: 100.0 }}) 100%
    );
    z-index: 2;
    pointer-events: none;
  }

  #GkHero-{{ section.id }} .gk-hero__content {
    position: relative;
    z-index: 3;
    text-align: {{ section.settings.text_alignment }};
    max-width: {{ section.settings.content_width }}px;
    padding: 60px 24px;
    width: 100%;
  }

  #GkHero-{{ section.id }} .gk-hero__eyebrow {
    font-family: 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 3px;
    font-size: 0.8rem;
    color: #E8690A;
    margin-bottom: 16px;
    display: block;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.6);
  }

  #GkHero-{{ section.id }} .gk-hero__heading {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3rem, 8vw, {{ section.settings.heading_size }}rem);
    line-height: 0.95;
    color: #E8E8E8;
    margin: 0 0 16px 0;
    text-transform: uppercase;
    letter-spacing: 2px;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.55);
  }

  #GkHero-{{ section.id }} .gk-hero__subheading {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.1rem;
    color: #C9C9C9;
    margin: 0 0 32px 0;
    line-height: 1.6;
    max-width: 600px;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.6);
    {% if section.settings.text_alignment == 'center' %}
      margin-left: auto;
      margin-right: auto;
    {% endif %}
  }

  #GkHero-{{ section.id }} .gk-hero__buttons {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    min-height: 52px;
    {% if section.settings.text_alignment == 'center' %}
      justify-content: center;
    {% endif %}
  }

  #GkHero-{{ section.id }} .gk-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 36px;
    border-radius: 999px;
    background: #E8690A;
    color: #0D0D0D;
    border: 1px solid #E8690A;
    font-family: 'DM Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: transform 140ms ease, opacity 140ms ease, box-shadow 140ms ease;
  }

  #GkHero-{{ section.id }} .gk-hero__btn:hover {
    opacity: 0.92;
    transform: translateY(-1px);
    box-shadow: 0 10px 26px rgba(232, 105, 10, 0.28);
  }

  #GkHero-{{ section.id }} .gk-hero__btn:active {
    transform: translateY(0);
  }

  #GkHero-{{ section.id }} .gk-hero__btn:focus-visible {
    outline: 2px solid rgba(232, 105, 10, 0.75);
    outline-offset: 3px;
  }

  /* Intro animation: image depth slide plus staggered text fly-in */
  #GkHero-{{ section.id }}.gk-hero--pre .gk-hero__media img,
  #GkHero-{{ section.id }}.gk-hero--pre .gk-hero__media video {
    opacity: 0;
    transform: translateY(12px) scale(1.09);
    will-change: transform, opacity;
  }

  #GkHero-{{ section.id }}.gk-hero--in .gk-hero__media img,
  #GkHero-{{ section.id }}.gk-hero--in .gk-hero__media video {
    opacity: 1;
    transform: translateY(0) scale(1);
    transition:
      opacity 700ms cubic-bezier(.16, .84, .44, 1),
      transform 900ms cubic-bezier(.16, .84, .44, 1);
  }

  #GkHero-{{ section.id }}.gk-hero--pre .gk-hero__eyebrow,
  #GkHero-{{ section.id }}.gk-hero--pre .gk-hero__heading,
  #GkHero-{{ section.id }}.gk-hero--pre .gk-hero__subheading,
  #GkHero-{{ section.id }}.gk-hero--pre .gk-hero__buttons {
    opacity: 0;
    transform: translateY(22px);
    will-change: transform, opacity;
  }

  #GkHero-{{ section.id }}.gk-hero--in .gk-hero__eyebrow {
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity 650ms cubic-bezier(.16, .84, .44, 1) 120ms,
      transform 650ms cubic-bezier(.16, .84, .44, 1) 120ms;
  }

  #GkHero-{{ section.id }}.gk-hero--in .gk-hero__heading {
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity 650ms cubic-bezier(.16, .84, .44, 1) 180ms,
      transform 650ms cubic-bezier(.16, .84, .44, 1) 180ms;
  }

  #GkHero-{{ section.id }}.gk-hero--in .gk-hero__subheading {
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity 650ms cubic-bezier(.16, .84, .44, 1) 260ms,
      transform 650ms cubic-bezier(.16, .84, .44, 1) 260ms;
  }

  #GkHero-{{ section.id }}.gk-hero--in .gk-hero__buttons {
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity 650ms cubic-bezier(.16, .84, .44, 1) 340ms,
      transform 650ms cubic-bezier(.16, .84, .44, 1) 340ms;
  }

  @media (prefers-reduced-motion: reduce) {
    #GkHero-{{ section.id }} .gk-hero__media img,
    #GkHero-{{ section.id }} .gk-hero__media video,
    #GkHero-{{ section.id }} .gk-hero__eyebrow,
    #GkHero-{{ section.id }} .gk-hero__heading,
    #GkHero-{{ section.id }} .gk-hero__subheading,
    #GkHero-{{ section.id }} .gk-hero__buttons {
      transition: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
  }

  @media screen and (max-width: 749px) {
    #GkHero-{{ section.id }} {
      min-height: {{ section.settings.mobile_height }}vh;
    }

    #GkHero-{{ section.id }} .gk-hero__heading {
      font-size: clamp(2.5rem, 10vw, 4rem);
    }
  }
{%- endstyle -%}

<section
  id="GkHero-{{ section.id }}"
  class="gk-hero{% if section.settings.enable_intro %} gk-hero--pre{% endif %}"
  data-gk-hero-intro="{{ section.settings.enable_intro }}"
>
  <div class="gk-hero__media">
    {%- if section.settings.video != blank -%}
      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true, preload: 'metadata' }}
    {%- elsif hero_image != blank -%}
      {{ hero_image | image_url: width: 2000 | image_tag:
        loading: 'eager',
        fetchpriority: 'high',
        sizes: '100vw',
        widths: '375, 750, 1100, 1500, 2000',
        alt: hero_image.alt | default: heading
      }}
    {%- else -%}
      <div style="width: 100%; height: 100%; background-color: #141414;"></div>
    {%- endif -%}
  </div>

  <div class="gk-hero__overlay"></div>

  <div class="gk-hero__content">
    {%- if eyebrow != blank -%}
      <span class="gk-hero__eyebrow">{{ eyebrow }}</span>
    {%- endif -%}

    {%- if heading != blank -%}
      <h1 class="gk-hero__heading">{{ heading }}</h1>
    {%- endif -%}

    {%- if subheading != blank -%}
      <p class="gk-hero__subheading">{{ subheading }}</p>
    {%- endif -%}

    <div class="gk-hero__buttons">
      {%- if button_label != blank -%}
        <a href="{{ button_link | default: routes.all_products_collection_url }}" class="gk-hero__btn">
          {{- button_label -}}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  (function () {
    var hero = document.getElementById('GkHero-{{ section.id }}');
    if (!hero || hero.getAttribute('data-gk-hero-intro') !== 'true') return;
    var reveal = function () {
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          hero.classList.remove('gk-hero--pre');
          hero.classList.add('gk-hero--in');
        });
      });
    };
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', reveal);
    } else {
      reveal();
    }
  })();
</script>

{% schema %}
{
  "name": "GK Hero",
  "tag": "section",
  "class": "gk-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Mode"
    },
    {
      "type": "paragraph",
      "content": "Standard is the everyday hero. Release swaps the copy and CTA for an album or product launch. Switching is this one dropdown, nothing else to rebuild."
    },
    {
      "type": "select",
      "id": "mode",
      "label": "Hero Mode",
      "default": "standard",
      "options": [
        { "value": "standard", "label": "Standard" },
        { "value": "release", "label": "Release" }
      ]
    },
    {
      "type": "header",
      "content": "Standard Mode Content"
    },
    {
      "type": "text",
      "id": "std_eyebrow",
      "label": "Eyebrow",
      "default": "Guitar Fiend. Gristle King."
    },
    {
      "type": "text",
      "id": "std_heading",
      "label": "Headline",
      "default": "Welcome to the Gristleverse"
    },
    {
      "type": "text",
      "id": "std_subheading",
      "label": "Subheadline",
      "default": "Guitars, gear, lessons, and music from Greg Koch."
    },
    {
      "type": "text",
      "id": "std_button_label",
      "label": "Button Label",
      "default": "Shop the Gristle"
    },
    {
      "type": "url",
      "id": "std_button_link",
      "label": "Button Link",
      "info": "Defaults to the all-products collection if left empty."
    },
    {
      "type": "header",
      "content": "Release Mode Content"
    },
    {
      "type": "text",
      "id": "rel_eyebrow",
      "label": "Eyebrow",
      "default": "New Release"
    },
    {
      "type": "text",
      "id": "rel_heading",
      "label": "Headline",
      "default": "NEW ALBUM: [Title], Out Now"
    },
    {
      "type": "text",
      "id": "rel_subheading",
      "label": "Subheadline",
      "default": "The new record from Greg Koch. Get your copy today."
    },
    {
      "type": "text",
      "id": "rel_button_label",
      "label": "Button Label",
      "default": "Get the Album"
    },
    {
      "type": "url",
      "id": "rel_button_link",
      "label": "Button Link",
      "info": "Point this at the release product page."
    },
    {
      "type": "image_picker",
      "id": "rel_image",
      "label": "Release Background Image",
      "info": "Optional. Falls back to the main hero image if empty."
    },
    {
      "type": "header",
      "content": "Background Media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Hero Video",
      "info": "Optional. Plays muted on a loop and takes priority over the image."
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Media Position",
      "default": "center center",
      "options": [
        { "value": "top center", "label": "Top" },
        { "value": "center center", "label": "Center" },
        { "value": "bottom center", "label": "Bottom" },
        { "value": "left center", "label": "Left" },
        { "value": "right center", "label": "Right" }
      ]
    },
    {
      "type": "header",
      "content": "Overlay (keeps text readable)"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Start Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 30,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "overlay_end_opacity",
      "label": "Overlay End Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 85,
      "unit": "%"
    },
    {
      "type": "select",
      "id": "gradient_direction",
      "label": "Gradient Direction",
      "default": "bottom",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "bottom", "label": "Bottom" },
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "hero_height",
      "label": "Hero Height",
      "min": 50,
      "max": 100,
      "step": 5,
      "default": 100,
      "unit": "vh"
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile Height",
      "min": 50,
      "max": 100,
      "step": 5,
      "default": 85,
      "unit": "vh"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content Vertical Position",
      "default": "flex-end",
      "options": [
        { "value": "flex-start", "label": "Top" },
        { "value": "center", "label": "Middle" },
        { "value": "flex-end", "label": "Bottom" }
      ]
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Content Max Width",
      "min": 600,
      "max": 1400,
      "step": 50,
      "default": 800,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Size",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 7,
      "unit": "rem"
    },
    {
      "type": "checkbox",
      "id": "enable_intro",
      "label": "Enable Intro Animation",
      "default": true,
      "info": "Image depth slide with staggered text reveal. Respects reduced motion settings."
    }
  ],
  "presets": [
    {
      "name": "GK Hero"
    }
  ]
}
{% endschema %}
